# DDEV LDAP container (.ddev/docker-compose.ldap.yaml, opt-in via `ddev ldap-on`).
# Overrides the localhost defaults in .env so `bin/console app:ldap:sync` talks
# to the container instead. Single LDAP, scope sub, simple bind as admin.
# When ldap-off, these still resolve but the connect fails fast — sync just
# reports the LDAP as unhealthy.
ldap_url=ldap://ldap.ddev.local:10389
ldap_bind_dn=uid=admin,ou=system
ldap_password=password
ldap_bind_type=simple
ldap_userName_attribute=uid
ldap_user_dn=o=testOrg,dc=example,dc=com
ldap_user_object_classes=inetOrgPerson,organizationalPerson,person
ldap_search_scope=sub
ldap_filter=(mail=*)
ldap_rdn_ldap_attribute=uid
ldap_uuid_ldap_attribute=entryUUID
ldap_server_individualName=ddev_ldap
ldap_attribute_mapper={"firstName":"givenName","lastName":"sn","email":"mail"}
ldap_special_Fields={"ou":"ou","departmentNumber":"departmentNumber"}
LDAP_DEPUTY_GROUP_OBJECTCLASS=groupOfNames
LDAP_DEPUTY_GROUP_DN=ou=groups,o=testOrg,dc=example,dc=com
LDAP_DEPUTY_GROUP_LEADER=owner
LDAP_DEPUTY_GROUP_MEMBERS=member
LDAP_DEPUTY_GROUP_FILTER=
LDAP_IS_SIP_VIDEO=false
LDAP_HOTSTANDBY_GROUP_DN=cn=hotstandby-a,ou=groups,o=testOrg,dc=example,dc=com
