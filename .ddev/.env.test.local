APP_ENV=test

DATABASE_URL=mysql://db:db@db:3306/test

# Point LDAP tests at the in-DDEV ApacheDS container (.ddev/docker-compose.ldap.yaml).
# Bind DN is uid=admin,ou=system. The admin password is reset from the ApacheDS
# default `secret` to `password` by the post-start hook in .ddev/config.yaml.
ldap_test_url=ldap://ldap.ddev.local:10389
ldap_url=ldap://ldap.ddev.local:10389;ldap://ldap.ddev.local:10389;ldap://ldap.ddev.local:10389
ldap_password=password;password;password

# Per-server hotstandby group DNs (| within a server, ; between servers).
LDAP_HOTSTANDBY_GROUP_DN=cn=hotstandby-a,ou=groups,o=testOrg,dc=example,dc=com|cn=hotstandby-b,ou=groups,o=testOrg,dc=example,dc=com;;
