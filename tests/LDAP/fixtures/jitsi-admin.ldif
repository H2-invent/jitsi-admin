# ---- Hotstandby device users (feature/hotstandby-device) ----
# uid == email so LDAP-sync's username matches Keycloak's login identifier.
# All three are members of cn=hotstandby-a so app:ldap:sync sets the same
# hotstandby_id on all three rows in ldap_user_properties. Password value
# below is a placeholder; actual login goes through Keycloak.
dn: uid=device1@hotstandby-test.de,o=testOrg,dc=example,dc=com
objectClass: inetOrgPerson
objectClass: organizationalPerson
objectClass: person
objectClass: top
cn: Device One
sn: One
givenName: Device
mail: device1@hotstandby-test.de
ou: HS
uid: device1@hotstandby-test.de
userPassword: hotstandby

dn: uid=device2@hotstandby-test.de,o=testOrg,dc=example,dc=com
objectClass: inetOrgPerson
objectClass: organizationalPerson
objectClass: person
objectClass: top
cn: Device Two
sn: Two
givenName: Device
mail: device2@hotstandby-test.de
ou: HS
uid: device2@hotstandby-test.de
userPassword: hotstandby

dn: uid=device3@hotstandby-test.de,o=testOrg,dc=example,dc=com
objectClass: inetOrgPerson
objectClass: organizationalPerson
objectClass: person
objectClass: top
cn: Device Three
sn: Three
givenName: Device
mail: device3@hotstandby-test.de
ou: HS
uid: device3@hotstandby-test.de
userPassword: hotstandby

# ---- Groups ----
dn: cn=sipVideoUser,dc=example,dc=com
objectClass: groupOfNames
objectClass: top
cn: sipVideoUser
member: uid=user9,o=testOrg,dc=example,dc=com
member: uid=user10,o=testOrg,dc=example,dc=com

dn: cn=deputyOfUser1,ou=groups,o=testOrg,dc=example,dc=com
objectClass: groupOfNames
objectClass: top
cn: deputyOfUser1
member: uid=user2,o=testOrg,dc=example,dc=com
member: uid=user3,o=testOrg,dc=example,dc=com
owner: uid=user1,o=testOrg,dc=example,dc=com

# ---- Hotstandby groups (feature/hotstandby-device) ----
# LdapUserService::resolveHotstandbyId reads the `member` attribute of each
# configured group DN to determine membership, so no memberOf overlay/
# interceptor on the LDAP server is required.
dn: cn=hotstandby-a,ou=groups,o=testOrg,dc=example,dc=com
objectClass: groupOfNames
objectClass: top
cn: hotstandby-a
member: uid=device1@hotstandby-test.de,o=testOrg,dc=example,dc=com
member: uid=device2@hotstandby-test.de,o=testOrg,dc=example,dc=com
member: uid=device3@hotstandby-test.de,o=testOrg,dc=example,dc=com

dn: cn=hotstandby-b,ou=groups,o=testOrg,dc=example,dc=com
objectClass: groupOfNames
objectClass: top
cn: hotstandby-b
member: uid=user2,o=testOrg,dc=example,dc=com
