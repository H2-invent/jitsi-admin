version: 1

# ---------------------------------------------------------------------------
# Test directory for jitsi-admin LDAP tests.
# Bind DN: uid=admin,ou=system (ApacheDS default)
# Mirrors the structure assumed by tests/LDAP/* and .env.test.
#
# Naming scheme:
#   - device<N>@hotstandby-test.de  → three hotstandby devices (cn=hotstandby-a)
#   - user1 .. user10               → o=testOrg branch (used by sync tests)
#   - user11 .. user15              → o=unitTest branch (used by UserShowTest)
#
# unitTest-branch users carry departmentNumber=99999 (unique across the
# directory) so UserShowTest can count them with `:contains("99999")` instead
# of relying on a uid substring.
# ---------------------------------------------------------------------------

dn: dc=example,dc=com
objectclass: domain
objectclass: top
dc: example

# ---- testOrg branch ----
dn: o=testOrg,dc=example,dc=com
objectClass: organization
objectClass: top
o: testOrg

dn: o=meinComp,o=testOrg,dc=example,dc=com
objectClass: organization
objectClass: top
o: meinComp

dn: o=meinCompSub,o=meinComp,o=testOrg,dc=example,dc=com
objectClass: organization
objectClass: top
o: meinCompSub

dn: ou=groups,o=testOrg,dc=example,dc=com
objectClass: organizationalUnit
objectClass: top
ou: groups

# ---- unitTest branch ----
dn: o=unitTest,dc=example,dc=com
objectClass: organization
objectClass: top
o: unitTest

dn: o=unitTestSub,o=unitTest,dc=example,dc=com
objectClass: organization
objectClass: top
o: unitTestSub

# ---- Users in testOrg (user1 .. user10) ----
dn: uid=user1,o=testOrg,dc=example,dc=com
objectClass: inetOrgPerson
objectClass: organizationalPerson
objectClass: person
objectClass: top
cn: User One
sn: One
departmentNumber: 12345
givenName: User
mail: user1@example.com
ou: AA
telephoneNumber: 0123456789
uid: user1
userPassword:: e1NIQTUxMn1zUW56dTd3a1RyZ2tRWkYrMEcxaGk1QUkzUW16dnYwYlhnYzVUS
 EJxaTdtQXNkZDRYbGwyN0FTYlJ0OWZFeWF2V2k2bTBRUDlCOGxUaGYrckRLeThoZz09

