<ul>

<li class="nav-item">
    <a class="nav-link" href="#" data-mdb-modal-init data-mdb-target="#helpModal">{{ 'Hilfe'|trans }}</a>
</li>
<li class="nav-item">
    {% if theme %}
        {% if theme.footerImprintEnable == true %}
            <a class="nav-link" target="_blank" referrerpolicy="no-referrer"
               href="{{ getApplicationProperties('imprint') }}">{{ theme.footerImprintText }}</a>
        {% endif %}
    {% else %}
        <a class="nav-link" target="_blank" referrerpolicy="no-referrer"
           href="{{ imprint }}">{{ 'Impressum'|trans }}</a>
    {% endif %}

</li>
<li class="nav-item">
    {% if theme %}
        {% if theme.footerGdprEnable == true %}
            <a class="nav-link" target="_blank" referrerpolicy="no-referrer"
               href="{{ getApplicationProperties('dataPrivacy') }}">{{ theme.footerGdprText }}</a>
        {% endif %}
    {% else %}
        <a class="nav-link" target="_blank" referrerpolicy="no-referrer"
           href="{{ dataPrivacy }}">{{ 'Datenschutzhinweis'|trans }}</a>
    {% endif %}
</li>

<li class="nav-item d-none d-xl-inline-block">

    <a class="nav-link"
       target="_blank"
       href="
{% if getApplicationProperties('LAF_HIDE_CHANGELOG') == 0 %}
            {{ path('app_changelog') }}
            {% else %}
            #
        {% endif %}
        "
            {% if time is defined %}
    data-mdb-tooltip-init title="{{ 'common.loadingTime'|trans }}: {{ time/1000 }}s"
            {% endif %}>

        {{ 'now'|date('Y') }} • v{{ laf_version }}

    </a>
</li>
{% if matomo_enable == '1' %}
    <li class="nav-item">
        <a class="nav-link" href="#" data-mdb-modal-init data-mdb-target="#exampleModal">
            Matomo Opt-out
        </a>
    </li>
{% endif %}

</ul>