<!DOCTYPE html>
<html lang="{{ app.request.locale|replace({ '_': '-' }) }}">
{% set theme =  getThemeProperties() %}
{{ include('base/__head.html.twig') }}

<script>
    var importBBB = true
</script>

{% if getApplicationProperties('laf_bbb') == 0 %}
    <script>
        var importBBB = false
    </script>
{% endif %}


<body {% if app.request.cookies.get('DARK_MODE') is defined and app.request.cookies.get('DARK_MODE') == 1 %}
    class="blackMode"{% endif %}>

<div id="mainContent" class="wrapper">

    <!-- Page Content  -->
    <div class="window" id="window">
        <div class="navigation fullwidth removeInIframe">
            <div class="container d-flex justify-content-between align-items-center">
                <div class="logo">
                    <a href="{{ path('dashboard') }}">
                        {% if theme %}
                            {% set logoSrc = (app.request.cookies.get('DARK_MODE') == 1 and theme.logoDarkmode is defined and theme.logoDarkmode) ? theme.logoDarkmode : theme.logo %}
                            <img class="d-none d-sm-block" src="{{ logoSrc }}" alt="Logo">
                            <img class="d-block d-sm-none" src="{{ logoSrc }}" alt="Logo">
                        {% else %}
                            <img class="d-none d-sm-block" src="{{ asset('logo.png') }}" alt="Logo">
                            <img class="d-block d-sm-none" src="{{ asset('logo_small.png') }}" alt="Logo">
                        {% endif %}
                    </a>
                </div>
                {% if theme != false %}
                    <p style="margin-bottom: 0; color:{{ theme.headerLineColor }}" class=" headerLine">
                        {{ theme.headerLine }}
                    </p>
                {% endif %}
                {% block CTA %}{% endblock %}
                <div class="fullwidth w-100 d-flex justify-content-end">
                    {% include('dashboard/widget/__profile_Dashboard.twig') %}
                </div>
            </div>
        </div>
        <div class="main">
            <div class="w-100 overflow-auto">
                <div class="subnavigation border-bottom">
                    <div class="container">
                        <div class="d-flex flex-wrap w-100 justify-content-between align-items-center">
                            <div class="d-flex flex-wrap align-items-center">
                                <div class="sidebarToggle sidebarToggle--sub d-xl-none">
                                    <i class="far fa-star"></i>
                                </div>
                                <div class="sidebarToggle sidebarToggle--sub d-none">
                                    <i class="fa fa-times"></i>
                                </div>
                                <a class="btn btn-outline-secondary btn-dashboard"
                                   data-mdb-modal-init
                                   data-mdb-target="#modalAdressbook"
                                   id="toggleAdressbook">
                                    <i class="fa fa-address-book me-1"></i>
                                    {{ 'Adressbuch'|trans }}
                                </a>
                                {% if input_settings_allow_roomPlanning == 1 %}
                                    <a href="{{ path('schedule_admin_new') }}"
                                       class="loadContent dashboardBtn btn btn-outline-primary btn-dashboard">
                                        <i class="fa-solid fa-square-poll-vertical me-1"></i>
                                        {{ 'Einen Termin finden'|trans }}
                                    </a>
                                {% endif %}
                            </div>
                            <div class="d-flex flex-wrap justify-content-end">
                                {% if input_settings_allow_sheduling == 1 %}
                                            <a href="{{ path('room_new') }}"
                                               class="loadContent dashboardBtn btn-primary btn btn-dashboard"
                                               id="createNewConference">
                                                <i class="fa-regular fa-calendar-plus me-1"></i>
                                                {{ 'Planen'|trans }}
                                            </a>
                                            {% if publicServer is defined and publicServer is not null %}
                                                <a href="{{ path('app_create_fast_confernce') }}"
                                                   class=" loadInMultiframe dashboardBtn btn-primary btn btn-dashboard"
                                                   id="createNewFastConference">
                                                    <i class="fas fa-play me-1"></i>
                                                    {{ 'Sofort'|trans }}
                                                </a>
                                            {% endif %}
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="container">
                    <div class="content mt-4">
                        <div class="sidebarToggle d-none">
                            <i class="fa fa-times fa-2x"></i>
                        </div>
                        <div class="sidebarToggle">
                            <i class="far fa-star fa-2x"></i>
                        </div>
                        <div class="sidebar" id="sidebar">
                            <div class="sidebarContent">
                                {% block sidebar %}{% endblock %}
                            </div>
                        </div>
                        <div class="body">
                            {% block body %}{% endblock %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer removeInIframe">
            <div class="container position-relative">
                {{ include('base/__footer.html.twig') }}
                {{ include('base/__proTips.html.twig') }}
            </div>
        </div>
    </div>
    {{ include('servers/__serverModal.html.twig') }}
    {{ include('base/__addressBookModal.html.twig') }}
    {{ include('base/__profileModal.html.twig') }}
    {{ include('base/__snack.html.twig') }}
    {{ include('base/__matomoOptOut.html.twig') }}
</div>


<div class="modal fade" id="loadContentModal" data-mdb-backdrop="static" tabindex="-1" role="dialog"
     aria-labelledby="loadContentModal"
     aria-hidden="true">
</div>
<div class="modal fade" id="helpModal" data-mdb-backdrop="static" tabindex="-1" role="dialog"
     aria-labelledby="helpModal"
     aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header  light-blue darken-3 white-text">
                <h5 class="modal-title" id="exampleModalLabel">{{ 'Hilfe'|trans }}</h5>
                <button type="button" class="btn-close" data-mdb-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                {{ getApplicationProperties('helpText')|raw }}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary"
                        data-mdb-dismiss="modal">{{ 'Schließen'|trans }}</button>

            </div>
        </div>
    </div>
</div>
<script>
    var urlNotification = '{{ path('notification') }}';
    var moreFeatureUrl = '{{ path('more_features') }}';
    var notificationUrl = "{{ laf_notificationUrl }}";
    var bbbUrl = "{{ getApplicationProperties('laf_bbb_Url') }}";
    var refreshDashboardTime = {{ laf_refreshTimeDashboard }};
    var refreshDashboardUrl = '{{ path('dashboard') }}';
    var confirmTitle = "{{ 'confirm.title'|trans }}";
    var confirmCancel = "{{ 'confirm.cancel'|trans }}";
    var confirmOk = "{{ 'confirm.ok'|trans }}";
</script>


{% block javascripts %}{% endblock %}
{{ include('base/__script.html.twig') }}

{% if theme and theme.extrahtml is defined %}
    {{ include(template_from_string(theme.extrahtml|raw)) }}
{% endif %}
<style type="text/css">
    .woot-widget-bubble {
        z-index: 5 !important;
    }
</style>
</body>

</html>
