<div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
    <div class="modal-content">

        <div class="modal-header  light-blue darken-3 white-text">
            <h5 class="modal-title">{{ 'Terminplaner'|trans }}</h5>
            <button type="button" class="btn-close" data-mdb-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
            <div class="row g-4">
                <div class="col-12 col-xl-6">
                    {% include 'schedule/_dateInput.html.twig' with {
                        reloadUrl: path('schedule_admin', {'id': room.id}),
                        addUrl: path('schedule_admin_add', {'id': room.id})
                    } %}

                    <div class="d-flex gap-2 mt-3">
                        {% if room.schedulings|length>0 %}
                            <a target="_blank"
                               href="{{ path('schedule_public_main',{'scheduleId':room.schedulings[0].uid,'userId':app.user.uid}) }}"
                               class="btn btn-primary w-100">{{ 'Hier zur Abstimmung'|trans }}
                                <i class="fa fa-external-link-alt"></i>
                            </a>
                        {% endif %}
                        <a href="{{ path('schedule_admin_participants',{'id':room.id}) }}"
                           class="btn btn-primary w-100">{{ 'Teilnehmer verwalten'|trans }}</a>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <h6>{{ 'Ergebnisse'|trans }}</h6>
                    <p class="small text-black-50 mb-3">{{ 'Hier sehen Sie die Abstimmungsergebnisse der Teilnehmer. Wählen Sie den passenden Termin aus, um eine Konferenz zu planen.'|trans }}</p>
                    <div id="scheduleSlots">
                        <div id="slot">
                            {% if room.schedulings|length>0 %}
                                <ul class="list-group">
                                    {% for s in room.schedulings[0].schedulingTimes|sort((a, b) => a.time <=> b.time) %}

                                        <li class="list-group-item d-flex flex-column schedulingTimeSlot">
                                            <div class="d-flex">
                                                <p class="mb-0">{{ s.time|date('d.m.Y  H:i') }}{% if s.createdFrom %}
                                                        <small>{{ s.createdFrom.email }}</small>{% endif %}</p>
                                            </div>
                                            <div class="d-flex align-items-center flex-column flex-sm-row">
                                                <div class="d-flex mb-2 mb-sm-0 w-100 gap-2 me-sm-2"
                                                     style="flex: 1">
                                                    <div class="chip btn-outline-success"
                                                         tabindex="0"
                                                         data-mdb-popover-init
                                                         data-mdb-trigger="focus"
                                                         data-mdb-html="true"
                                                         title="{{ 'Abstimmung'|trans }}"
                                                         data-mdb-content="{% if scheduleUser(s,0)|length >0 %}{% for s in scheduleUser(s,0) %}{{ s.user.email }}<br>{% endfor %}{% else %}{{ 'Keine Abstimmungen'|trans }}{% endif %}">
                                                        <div class="symbol">
                                                            <i class="fa fa-check"></i>
                                                        </div>
                                                        <div class="content">
                                                            {{ scheduleNumber(s,0) }}
                                                        </div>
                                                    </div>

                                                    <div class="chip btn-outline-danger"
                                                         tabindex="0"
                                                         data-mdb-popover-init
                                                         data-mdb-trigger="focus"
                                                         data-mdb-html="true"
                                                         title="{{ 'Abstimmung'|trans }}"
                                                         data-mdb-content="{% if scheduleUser(s,1)|length >0 %}{% for s in scheduleUser(s,1) %}{{ s.user.email }}<br>{% endfor %}{% else %}{{ 'Keine Abstimmungen'|trans }}{% endif %}">
                                                        <div class="symbol">
                                                            <i class="fa fa-times"></i>
                                                        </div>
                                                        <div class="content">
                                                            {{ scheduleNumber(s,1) }}
                                                        </div>
                                                    </div>

                                                    {% if room.allowMaybeOption %}
                                                        <div class="chip btn-outline-warning"
                                                             tabindex="0"
                                                             data-mdb-popover-init
                                                             data-mdb-trigger="focus"
                                                             data-mdb-html="true"
                                                             title="{{ 'Abstimmung'|trans }}"
                                                             data-mdb-content="{% if scheduleUser(s,2)|length >0 %}{% for s in scheduleUser(s,2) %}{{ s.user.email }}<br>{% endfor %}{% else %}{{ 'Keine Abstimmungen'|trans }}{% endif %}">
                                                            <div class="symbol">
                                                                <i class="fa fa-question"></i>
                                                            </div>
                                                            <div class="content">
                                                                {{ scheduleNumber(s,2) }}
                                                            </div>
                                                        </div>
                                                    {% endif %}

                                                </div>

                                                <div class="d-flex gap-1" style="flex: 0">
                                                    <button class="btn btn-link btn-sm text-muted removeSchedule" style="width: 2rem; height: 2rem; padding: 0; line-height: 2rem; text-align: center;"
                                                            data-mdb-tooltip-init title="{{ 'Termin löschen'|trans }}"
                                                            type="button"
                                                            data-reload="{{ path('schedule_admin',{'id':room.id}) }}"
                                                            data-url="{{ path('schedule_admin_remove',{'id':s.id}) }}"
                                                            data-text="{{ "confirm.schedule.delete"|trans }}"
                                                            data-textok="{{ "confirm.ok"|trans }}"
                                                            data-textcancel="{{ "confirm.cancel"|trans }}"
                                                            data-texttitle="{{ "confirm.title"|trans }}"
                                                    >
                                                        <i class="fa fa-trash"></i>
                                                    </button>
                                                    <a href="{{ path('schedule_admin_choose',{'id':s.id}) }}"
                                                       class="btn btn-primary btn-sm text-white text-nowrap confirmHref"
                                                       data-mdb-tooltip-init title="{{ 'Termin wählen und Konferenz planen'|trans }}"
                                                       data-text="{{ 'Wollen Sie diese Terminplanung in eine Konferenz umwandeln?'|trans }}">
                                                        <i class="fa fa-check me-1"></i>{{ 'Termin'|trans }}</a>
                                                </div>

                                            </div>

                                        </li>

                                    {% endfor %}
                                </ul>
                            {% endif %}
                        </div>
                    </div>
                    <a href="{{ path('schedule_download_csv',{'id':room.id}) }}"
                       class="btn btn-outline-primary mt-2 w-100">{{ 'Als CSV Downloaden'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
</div>
