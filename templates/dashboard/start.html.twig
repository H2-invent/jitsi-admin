<!DOCTYPE html>
<html lang="{{ app.request.locale|replace({ '_': '-' }) }}">
<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="description" content="">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="manifest" href="{{ asset('site.webmanifest') }}">

    <title>Jitsi Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    {{ encore_entry_link_tags('startpage') }}

    <script type="application/ld+json">
        {
            "@context": "http://schema.org",
            "@type": "SoftwareApplication",
            "name": "Jitsi Admin",
            "image": "https://jitsi-admin.de/logo.png",
            "url": "https://jitsi-admin.de/",
            "publisher": {
                "@type": "Organization",
                "name": "H2 Invent GmbH"
            },
            "applicationCategory": "Open Source",
            "downloadUrl": "https://github.com/H2-invent/jitsi-admin",
            "operatingSystem": "LAMP Server",
            "requirements": "PHP >7.3",
            "screenshot": "https://jitsi-admin.de/images/start/screenshots.png"
        }
    </script>
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "QAPage",
            "mainEntity": {
                "@type": "Question",
                "name": "Wie kann ich bei einem Jitsi Server Termine erstellen",
                "text": "Ich habe einen Jitsi-Meet-Server und möchte eine Konferenz zu einem Zeitpunkt organisieren und sichergehen dass keine anderen Benutzer als die eingeladenen Personen in die Konferenz kommen. Gibt es dazu eine Möglichkeit bei Jitsi-Meet?",
                "answerCount": 1,
                "author": {
                    "@type": "Person",
                    "name": "Anonymous User"
                },
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Mit Jitsi-Admin, einer Open Source Software kannst du deinen Jitsi-Server absichern und über das Dashboard jederzeit Termine organisieren. Der Jitsi-Admin lässt sich für jeden Jitsi-Server verwenden und muss dort nur als 'Mein Server hinzugefügt werden.'",
                    "url": "https://jitsi-admin.de/",
                    "author": {
                        "@type": "person",
                        "name": "H2 Invent GmbH"
                    }
                }
            }
        }
    </script>
    {{ include('base/__matomo.html.twig') }}
    <meta property="og:title" content="Jitsi-Admin, die Open Source Plattform für Ihre Jitsi-Meetings"/>
    <meta property="og:description"
          content="Erstellen Sie mit Jitsi-Admin ihre Jitsi Meetings und laden Sie Freunde und Bekannt ein. Das alles unkompliziert und kostenlos."/>
    <meta property="og:url" content="{{ absolute_url(path('index')) }}"/>
    <meta property="og:image" content="{{ absolute_url(asset('logo.png')) }}"/>

    <meta name="twitter:title" content="Jitsi-Admin, die Open Source Plattform für Ihre Jitsi-Meetings">
    <meta name="twitter:description"
          content="Erstellen Sie mit Jitsi-Admin ihre Jitsi Meetings und laden Sie Freunde und Bekannt ein. Das alles unkompliziert und kostenlos.">
    <meta name="twitter:image" content="{{ absolute_url(asset('logo.png')) }}">
    <meta name="twitter:card" content="summary_large_image">

    <link rel="icon" href="favicon.ico">
</head>
<body class="hp-body">

<!-- Navigation -->
<nav class="hp-nav fixed-top">
    <div class="container-fluid">
        <div class="hp-nav-container">
            <div class="d-flex align-items-center">
                <a class="hp-nav-brand" href="/">
                    <img src="{{ asset('logo.png') }}" alt="Jitsi Admin" class="hp-nav-logo">
                    <span class="hp-nav-brand-text">Jitsi Admin</span>
                </a>
            </div>
            <div class="hp-nav-right d-none d-lg-flex align-items-center">
                <a class="hp-btn hp-btn-primary hp-btn-sm" href="{{ path('dashboard') }}">{{ 'hp.nav.login'|trans({}, 'homepage') }}</a>
                <a class="hp-btn hp-btn-outline hp-btn-sm" href="{{ path('register_keycloak') }}">{{ 'hp.nav.register'|trans({}, 'homepage') }}</a>
                <div class="hp-lang">
                    <button class="hp-lang-toggle" type="button" id="langToggle">
                        <img src="{{ asset('images/locale/' ~ app.request.locale ~ '.png') }}" alt="" class="hp-lang-flag">
                        <svg class="hp-lang-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 1l4 4 4-4"/></svg>
                    </button>
                    <div class="hp-lang-menu" id="langMenu">
                        <a class="hp-lang-item" href="{{ path(app.request.get('_route'), app.request.get('_route_params') | merge({'_locale':'en'})) }}">
                            <img src="{{ asset('images/locale/en.png') }}" alt="EN" class="hp-lang-flag"> English
                        </a>
                        <a class="hp-lang-item" href="{{ path(app.request.get('_route'), app.request.get('_route_params') | merge({'_locale':'de'})) }}">
                            <img src="{{ asset('images/locale/de.png') }}" alt="DE" class="hp-lang-flag"> Deutsch
                        </a>
                    </div>
                </div>
            </div>
            <button class="hp-nav-toggle d-lg-none" type="button" id="navToggle">
                <span></span><span></span><span></span>
            </button>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<main id="header" class="hp-hero d-flex align-items-center justify-content-center">
    <div class="container w-100 position-relative hp-hero-content">
        <div class="hp-grid-bg">
            {% for i in 0..3 %}
            <div class="hp-grid-col">
                <div class="hp-grid-line hp-grid-line-left"></div>
                <div class="hp-grid-line hp-grid-line-right"></div>
            </div>
            {% endfor %}
        </div>

        <div class="row justify-content-center text-center">
            <div class="col-12">
                <div class="mx-auto hp-hero-heading-wrapper">
                    <h2 class="hp-hero-heading">
                        {% set words = 'hp.meta.heading'|trans({}, 'homepage')|split(' ') %}
                        {% for word in words %}
                        <span class="hp-hero-word">{{ word }}</span>
                        {% endfor %}
                    </h2>
                </div>

                <p class="hp-hero-subheading mx-auto">
                    {{ 'hp.hero.subheading'|trans({}, 'homepage') }}
                </p>

                <div class="hp-hero-cta d-flex flex-wrap align-items-center justify-content-center">
                    <a class="hp-btn hp-btn-primary hp-btn-lg" href="{{ path('dashboard') }}">{{ 'hp.hero.login'|trans({}, 'homepage') }}</a>
                    <a class="hp-btn hp-btn-white hp-btn-lg" href="{{ path('register_keycloak') }}">{{ 'hp.hero.register'|trans({}, 'homepage') }}</a>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-12">
                <div class="hp-hero-screenshot">
                    <div class="hp-hero-screenshot-inner">
                        <img class="hp-hero-screenshot-img" src="{{ asset(app.request.locale starts with 'de' ? 'images/start/dashboard_home_de.png' : 'images/start/dashboard_home_en.png') }}" alt="Jitsi Admin Dashboard">
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

